        <mxCell id="ev4" value="" style="ellipse;whiteSpace=wrap;html=1;strokeColor=none;fillColor=#14532d;" vertex="1" parent="1"><mxGeometry x="1638" y="439" width="9" height="9" as="geometry" /></mxCell>
        <mxCell id="practical-card" value="&lt;b&gt;Practical utility tasks&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Classification metrics, image retrieval, and image-to-concept retrieval are computed for every embedding set.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;strokeColor=none;fillColor=#ffffff;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=15;fontColor=#14532d;align=left;verticalAlign=top;spacingLeft=18;spacingRight=18;spacingTop=16;spacingBottom=14;" vertex="1" parent="1"><mxGeometry x="1508" y="525" width="226" height="125" as="geometry" /></mxCell>
