        <mxCell id="tp" value="+" style="ellipse;whiteSpace=wrap;html=1;strokeColor=none;fillColor=#fb923c;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=9;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="890" y="450" width="18" height="18" as="geometry" /></mxCell>
        <mxCell id="tn" value="-" style="ellipse;whiteSpace=wrap;html=1;strokeColor=none;fillColor=#fed7aa;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=9;fontStyle=1;fontColor=#7c2d12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="950" y="450" width="18" height="18" as="geometry" /></mxCell>
        <mxCell id="v1-card" value="&lt;b&gt;v1 human&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Continue from baseline with fixed train-image prototypes and triplet regularization.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;strokeColor=none;fillColor=#ffffff;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=15;fontColor=#9a3412;align=left;verticalAlign=top;spacingLeft=18;spacingRight=18;spacingTop=16;spacingBottom=14;" vertex="1" parent="1"><mxGeometry x="764" y="545" width="132" height="150" as="geometry" /></mxCell>
        <mxCell id="v1s-card" value="&lt;b&gt;v1 shuffled&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Same schedule and triplet count; positive and negative assignments are shuffled.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;strokeColor=none;fillColor=#ffffff;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=15;fontColor=#9a3412;align=left;verticalAlign=top;spacingLeft=18;spacingRight=18;spacingTop=16;spacingBottom=14;" vertex="1" parent="1"><mxGeometry x="912" y="545" width="132" height="150" as="geometry" /></mxCell>
        <mxCell id="v1-vis" value="real" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;strokeColor=none;fillColor=#c2410c;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=10;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="800" y="714" width="60" height="20" as="geometry" /></mxCell>
        <mxCell id="shuffle-vis" value="shuffled" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;strokeColor=none;fillColor=#fb923c;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=10;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="942" y="714" width="74" height="20" as="geometry" /></mxCell>
        <mxCell id="v2v3-card" value="&lt;b&gt;v2/v3 dynamic variants&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Test current-batch concept triplets and altered classification-vs-human loss weighting.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;strokeColor=none;fillColor=#ffffff;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=15;fontColor=#9a3412;align=left;verticalAlign=top;spacingLeft=18;spacingRight=18;spacingTop=16;spacingBottom=14;" vertex="1" parent="1"><mxGeometry x="764" y="810" width="280" height="125" as="geometry" /></mxCell>
        <mxCell id="loss-vis" value="CE + human" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;strokeColor=none;fillColor=#c2410c;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=11;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="846" y="956" width="116" height="22" as="geometry" /></mxCell>

        <!-- matrix -->
        <mxCell id="matrix-card" value="&lt;b&gt;Similarity-matrix objective&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;In each batch, align the model concept-similarity matrix to the human similarity matrix.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;strokeColor=none;fillColor=#ffffff;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=15;fontColor=#991b1b;align=left;verticalAlign=top;spacingLeft=18;spacingRight=18;spacingTop=16;spacingBottom=14;" vertex="1" parent="1"><mxGeometry x="1152" y="285" width="246" height="125" as="geometry" /></mxCell>
        <mxCell id="matrix-vis" value="" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;strokeColor=none;fillColor=#fff0dc;" vertex="1" parent="1"><mxGeometry x="1195" y="430" width="154" height="52" as="geometry" /></mxCell>
        <mxCell id="mv1" value="" style="rounded=0;strokeColor=none;fillColor=#fed7aa;" vertex="1" parent="1"><mxGeometry x="1210" y="442" width="16" height="16" as="geometry" /></mxCell>
        <mxCell id="mv2" value="" style="rounded=0;strokeColor=none;fillColor=#fb923c;" vertex="1" parent="1"><mxGeometry x="1230" y="442" width="16" height="16" as="geometry" /></mxCell>
