        <mxCell id="bar2" value="" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;strokeColor=none;fillColor=#2b7c2f;" vertex="1" parent="1"><mxGeometry x="1608" y="660" width="10" height="22" as="geometry" /></mxCell>
        <mxCell id="bar3" value="" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;strokeColor=none;fillColor=#14532d;" vertex="1" parent="1"><mxGeometry x="1624" y="650" width="10" height="32" as="geometry" /></mxCell>
        <mxCell id="thingsplus-card" value="&lt;b&gt;THINGSplus transfer&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Evaluate category structure, nameability, lexical variables, typicality, and object-property norms without using them in training.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;strokeColor=none;fillColor=#ffffff;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=15;fontColor=#14532d;align=left;verticalAlign=top;spacingLeft=18;spacingRight=18;spacingTop=16;spacingBottom=14;" vertex="1" parent="1"><mxGeometry x="1508" y="730" width="226" height="145" as="geometry" /></mxCell>
        <mxCell id="tp-chip1" value="name" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;strokeColor=none;fillColor=#bfdbfe;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=9;fontStyle=1;fontColor=#1e3a8a;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1542" y="896" width="48" height="16" as="geometry" /></mxCell>
        <mxCell id="tp-chip2" value="typical" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;strokeColor=none;fillColor=#bbf7d0;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=9;fontStyle=1;fontColor=#166534;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1598" y="896" width="58" height="16" as="geometry" /></mxCell>
        <mxCell id="tp-chip3" value="props" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;strokeColor=none;fillColor=#ffd69a;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=9;fontStyle=1;fontColor=#7c2d12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1662" y="896" width="48" height="16" as="geometry" /></mxCell>
        <mxCell id="human-eval-card" value="&lt;b&gt;Human-source alignment&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Compare model similarity structure against held-out human pair information and triplet satisfaction diagnostics.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;strokeColor=none;fillColor=#ffffff;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=15;fontColor=#14532d;align=left;verticalAlign=top;spacingLeft=18;spacingRight=18;spacingTop=16;spacingBottom=14;" vertex="1" parent="1"><mxGeometry x="1508" y="960" width="226" height="125" as="geometry" /></mxCell>
