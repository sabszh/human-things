        <mxCell id="mv4" value="" style="rounded=0;strokeColor=none;fillColor=#ffd69a;" vertex="1" parent="1"><mxGeometry x="1210" y="462" width="16" height="16" as="geometry" /></mxCell>
        <mxCell id="mv5" value="" style="rounded=0;strokeColor=none;fillColor=#fed7aa;" vertex="1" parent="1"><mxGeometry x="1230" y="462" width="16" height="16" as="geometry" /></mxCell>
        <mxCell id="mv6" value="" style="rounded=0;strokeColor=none;fillColor=#fb923c;" vertex="1" parent="1"><mxGeometry x="1250" y="462" width="16" height="16" as="geometry" /></mxCell>
        <mxCell id="matrix-label" value="matrix loss" style="text;html=1;strokeColor=none;fillColor=none;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=10;fontColor=#991b1b;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1278" y="450" width="58" height="18" as="geometry" /></mxCell>
        <mxCell id="joint-card" value="&lt;b&gt;Joint training from ImageNet init&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Train with THINGS classification and matrix loss from the beginning, using baseline-matched settings.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;strokeColor=none;fillColor=#ffffff;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=15;fontColor=#991b1b;align=left;verticalAlign=top;spacingLeft=18;spacingRight=18;spacingTop=16;spacingBottom=14;" vertex="1" parent="1"><mxGeometry x="1152" y="555" width="246" height="140" as="geometry" /></mxCell>
        <mxCell id="joint-vis" value="CE loss + matrix loss" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;strokeColor=none;fillColor=#b91c1c;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=10;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1192" y="720" width="166" height="22" as="geometry" /></mxCell>
        <mxCell id="shuffle-matrix-card" value="&lt;b&gt;Shuffled matrix control&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Repeat joint training after permuting the human matrix while keeping the same schedule.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;strokeColor=none;fillColor=#ffffff;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=15;fontColor=#991b1b;align=left;verticalAlign=top;spacingLeft=18;spacingRight=18;spacingTop=16;spacingBottom=14;" vertex="1" parent="1"><mxGeometry x="1152" y="810" width="246" height="125" as="geometry" /></mxCell>
        <mxCell id="shuffle-matrix-vis" value="permute rows/cols" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;strokeColor=none;fillColor=#fb7185;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=10;fontStyle=1;fontColor=#ffffff;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1212" y="956" width="118" height="22" as="geometry" /></mxCell>

        <!-- evaluation -->
        <mxCell id="extract-card" value="&lt;b&gt;Embedding extraction&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;For every trained model, remove the classifier head and save image-level and concept-level embeddings.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;strokeColor=none;fillColor=#ffffff;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=15;fontColor=#14532d;align=left;verticalAlign=top;spacingLeft=18;spacingRight=18;spacingTop=16;spacingBottom=14;" vertex="1" parent="1"><mxGeometry x="1508" y="285" width="226" height="125" as="geometry" /></mxCell>
