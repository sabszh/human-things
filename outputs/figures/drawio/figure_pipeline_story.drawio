        <mxCell id="baseline-train-card" value="&lt;b&gt;Two-stage fine-tuning&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Train classifier head first; then unfreeze layer4 with a lower learning rate.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;strokeColor=none;fillColor=#ffffff;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=15;fontColor=#1e3a8a;align=left;verticalAlign=top;spacingLeft=18;spacingRight=18;spacingTop=16;spacingBottom=14;" vertex="1" parent="1"><mxGeometry x="410" y="555" width="246" height="120" as="geometry" /></mxCell>
        <mxCell id="train-vis" value="head → layer4" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;strokeColor=none;fillColor=#cfe3ff;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=11;fontStyle=1;fontColor=#1e3a8a;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="458" y="700" width="150" height="26" as="geometry" /></mxCell>
