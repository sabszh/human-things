        <mxCell id="audit-card" value="&lt;b&gt;Audit trail&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;JSON checks record image existence, concept matching, split counts, pair overlap, triplet gaps, and shuffled controls.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;strokeColor=none;fillColor=#ffffff;fontFamily=Inter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DInter;fontSize=15;fontColor=#1e3a8a;align=left;verticalAlign=top;spacingLeft=18;spacingRight=18;spacingTop=16;spacingBottom=14;" vertex="1" parent="1"><mxGeometry x="56" y="810" width="246" height="125" as="geometry" /></mxCell>
